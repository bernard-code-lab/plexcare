# URL base da API de autenticação (idp).
# Dev local (placeholder): http://localhost:8090
VITE_AUTH_API_URL=http://localhost:8090

# Issuer Keycloak (realm completo). Usado quando rodar via OIDC.
# Ex.: http://localhost:8081/realms/plexcare
VITE_OIDC_ISSUER=http://localhost:8081/realms/plexcare

# Client público (SPA) cadastrado no Keycloak realm plexcare.
VITE_OIDC_CLIENT_ID=plexcare-web

# Redirect URI pós-login (rota da SPA destino).
# Cada app web (teleconf-web, schedule-web…) registra a sua.
VITE_DEFAULT_REDIRECT_URI=http://localhost:5174/

# Habilita providers de login social (true/false).
VITE_ENABLE_GOOGLE=true
VITE_ENABLE_APPLE=false
VITE_ENABLE_MICROSOFT=false

# Endereço de suporte exibido na tela.
VITE_SUPPORT_EMAIL=suporte@plexcare.com.br

# =============================================================================
# plexcare-idp-api — example env (copy to .env)
# All paths/hosts/ports are parameterizable. The compose file below is only a
# local convenience — production endpoints come from the deployment env.
# =============================================================================

PORT=4000
NODE_ENV=development

# -----------------------------------------------------------------------------
# DATABASE — totalmente parametrizado (host/porta/credenciais/db).
# O default aponta para o docker-compose local na porta 3307.
# Cloud / CI: reescrever via env do orquestrador.
# -----------------------------------------------------------------------------
DATABASE_URL=mysql://plexcare:plexcare@localhost:3307/db_plexcare_tenancy

# -----------------------------------------------------------------------------
# KEYCLOAK
# -----------------------------------------------------------------------------
KEYCLOAK_BASE_URL=http://localhost:8088
KEYCLOAK_REALM=plexcare
KEYCLOAK_ADMIN_CLIENT_ID=idp-api-admin
KEYCLOAK_ADMIN_CLIENT_SECRET=changeme

# -----------------------------------------------------------------------------
# KAFKA
# -----------------------------------------------------------------------------
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=plexcare-idp-api

# -----------------------------------------------------------------------------
# SMTP (em dev, mailhog na porta 1025; em prod, AWS SES SMTP relay)
# -----------------------------------------------------------------------------
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_FROM=noreply@plexcare.com.br

# -----------------------------------------------------------------------------
# JWKS / KEY ENCRYPTION
# Em dev: provider=env (KEK lida de JWKS_KEK_DEV).
# Em prod: provider=kms (adapter AWS KMS — placeholder até cloud target ser definido).
# Boot falha-fast se NODE_ENV=production && JWKS_KEK_PROVIDER=env.
# -----------------------------------------------------------------------------
JWKS_KEK_PROVIDER=env
JWKS_KEK_DEV=replace-with-32-bytes-base64-aqui
JWKS_KMS_KEY_ID=

# -----------------------------------------------------------------------------
# ISSUER / CORS
# -----------------------------------------------------------------------------
ISSUER_URL=http://localhost:4000
CORS_ALLOWED_ORIGINS=http://localhost:5175,http://localhost:5176

# -----------------------------------------------------------------------------
# TTLs (segundos)
# -----------------------------------------------------------------------------
PKCE_STATE_TTL_SECONDS=300
RESET_TOKEN_TTL_SECONDS=1800
EMAIL_VERIFY_TTL_SECONDS=86400
IDEMPOTENCY_TTL_SECONDS=900

# -----------------------------------------------------------------------------
# LOCKOUT (anti-bruteforce)
# -----------------------------------------------------------------------------
LOCKOUT_WINDOW_SECONDS=300
LOCKOUT_THRESHOLD=5
LOCKOUT_BLOCK_SECONDS=900

# -----------------------------------------------------------------------------
# OBSERVABILIDADE
# -----------------------------------------------------------------------------
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
LOG_LEVEL=info

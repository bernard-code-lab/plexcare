# URL do plexcare-teleconf-service (REST API).
# Dev local (docker compose): http://localhost:8080
VITE_TELECONF_SERVICE_URL=http://localhost:8080

# URL pública do LiveKit (WebSocket signal).
# Dev local: ws://localhost:7880
VITE_LIVEKIT_URL=ws://localhost:7880

# Tenant ID em dev (qualquer UUID v4 — o devtenant resolver aceita).
# Em prod, virá do token de auth.
VITE_DEV_TENANT_ID=00000000-0000-4000-8000-000000000001

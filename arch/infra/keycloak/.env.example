# ============================================================================
# PlexCare Keycloak — variáveis de ambiente (DEV)
# ============================================================================
# Copie para .env e preencha. NUNCA commitar .env (já está no .gitignore raiz).
# Em produção use Secrets Manager / SSM Parameter Store / External Secrets.
# ============================================================================

# ---------- Versão ----------
KEYCLOAK_VERSION=26.0.7

# ---------- Postgres ----------
KC_DB_NAME=keycloak
KC_DB_USERNAME=keycloak
# Gere com: openssl rand -base64 32
KC_DB_PASSWORD=change-me-please-min-32-chars

# ---------- Admin bootstrap ----------
# Esse usuário é criado SOMENTE no primeiro boot. Depois disso, troque a senha
# pelo console admin e remova/rotacione esta variável.
KC_BOOTSTRAP_ADMIN_USERNAME=admin
# Gere com: openssl rand -base64 24
KC_BOOTSTRAP_ADMIN_PASSWORD=change-me-on-first-login

# ---------- Hostname ----------
# DEV: http cleartext
KC_HOSTNAME=http://localhost:8080
# PROD exemplo: https://auth.plexcare.com.br
KC_LOG_LEVEL=INFO

# ============================================================================
# Identity Providers — preencher com as credenciais reais do tenant master
# ============================================================================
# Cada cliente PlexCare pode (mais tarde) sobrescrever esses providers no
# nível do realm via console admin ou via API kcadm.sh.

# ---------- Google ----------
# Console: https://console.cloud.google.com/apis/credentials
# Tipo de credencial: OAuth 2.0 Client ID → Web application
# Authorized redirect URI:
#   http://localhost:8080/auth/realms/plexcare/broker/google/endpoint
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ---------- Apple (Sign in with Apple) ----------
# Apple Developer: https://developer.apple.com/account/resources/identifiers/list/serviceId
# 1. Crie um Services ID (será o APPLE_CLIENT_ID)
# 2. Configure "Sign In with Apple" com Return URL:
#    http://localhost:8080/auth/realms/plexcare/broker/apple/endpoint
# 3. Gere uma Key (.p8) com "Sign In with Apple" habilitado
# 4. Use o conteúdo da .p8 + Key ID + Team ID para gerar o client_secret JWT
#    (Keycloak gera o JWT automaticamente quando você usa a chave .p8;
#     o "APPLE_CLIENT_SECRET" abaixo é o conteúdo da chave .p8 em base64).
APPLE_CLIENT_ID=
APPLE_CLIENT_SECRET=
APPLE_TEAM_ID=
APPLE_KEY_ID=

# ---------- Facebook / Meta (cobre o ecossistema WhatsApp) ----------
# WhatsApp em si não tem OAuth público. Use Meta para login social no ecossistema.
# https://developers.facebook.com/apps → Facebook Login → Settings
# Valid OAuth Redirect URI:
#   http://localhost:8080/auth/realms/plexcare/broker/facebook/endpoint
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=

# ---------- WhatsApp OTP (Cloud API) — opcional, via Authenticator SPI ----------
# Para login passwordless por código WhatsApp, precisamos do Cloud API:
# https://developers.facebook.com/docs/whatsapp/cloud-api
# Esses valores são lidos pelo provider customizado em providers/whatsapp-otp.jar
# (ainda a implementar — ver README).
WHATSAPP_BUSINESS_PHONE_ID=
WHATSAPP_BUSINESS_TOKEN=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_OTP_TEMPLATE_NAME=plexcare_otp

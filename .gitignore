# dependencies
node_modules/

# build output
dist/
dist-ssr/

# logs
*.log
npm-debug.log*

# editor / OS
.DS_Store
.idea/
.vscode/*
!.vscode/extensions.json
*.local

# env
.env
.env.*
!.env.example

# Re-include markdown — the user's global excludes (~/.gitignore_global)
# has a "*.MD" rule that, on case-insensitive macOS, also ignores *.md files.
!*.md
!**/*.md
